{
  "name": "mland",
  "version": "0.1.0",
  "private": true,
  "description": "企业级 AI 智能体解决方案 — 三甲医院私有化部署",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "mcp-server"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:packages": "npm run build --workspace=@mland/agent --workspace=@mland/core --workspace=@mland/mcp-server --workspace=mland-cli",
    "start": "next start",
    "lint": "next lint",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "mcp": "npm run start --workspace=@mland/mcp-server"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-checkbox": "^1.3.5",
