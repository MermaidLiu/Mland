# Mland 官网环境变量

# 数据库（后续 Prisma 集成时使用）
DATABASE_URL="file:./dev.db"

# 应用名称
NEXT_PUBLIC_APP_NAME="Mland"

# GitHub 仓库地址
NEXT_PUBLIC_GITHUB_REPO_URL="https://github.com/MermaidLiu/Mland"

# 管理后台密码（后续 /admin 使用）
ADMIN_PASSWORD="change-me-in-production"

# Agent Playground 演示 API Key（可选，不配置则使用模拟回复）
AGENT_DEMO_API_KEY=""
